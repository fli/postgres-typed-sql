diff --git a/build-with-docker.sh b/build-with-docker.sh
index 0db48f3a39..a5f272ee12 100755
--- a/build-with-docker.sh
+++ b/build-with-docker.sh
@@ -1,5 +1,5 @@
-# although we could use any path inside docker, using the same path as on the host
-# allows the DWARF info (when building in DEBUG) to contain the correct file paths
-DOCKER_WORKSPACE=$(pwd)
+# A stable container path makes release-build intermediates relocatable between
+# private copy-on-write worktree clones.
+DOCKER_WORKSPACE=/workspace
 echo "PGLITE_VERSION=${PGLITE_VERSION}"
 echo "DEBUG=${DEBUG}"
